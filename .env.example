# 이 파일을 복사해 .env로 만들고 값을 채움. .env는 git에 올리지 않음.
#
# 주의: Spring Boot는 .env를 자동으로 읽지 않음. 아래 셋 중 하나로 주입함.
#   1) IntelliJ: Run/Debug Configurations -> Environment variables에 붙여넣기
#   2) bash:     set -a; source .env; set +a; ./gradlew bootRun --args='--spring.profiles.active=local'
#   3) PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^(\w+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }

# --- DB (compose.yml 기본값과 일치함) ---
DB_URL=jdbc:mysql://localhost:3306/jeongbiseo?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=jeongbiseo
DB_PASSWORD=jeongbiseo

# --- 소셜 로그인 (정비서는 kakao + google, naver 없음) ---
# 방식 B임: 인가 URL 조립과 PKCE code_verifier·state 소유는 프론트이고, 백엔드는 code 교환만 함.
# 그래서 redirect_uri는 백엔드 환경변수가 아님. 프론트가 자기 콜백 URL을
# POST /api/v1/auth/{provider} 요청 바디로 보냄(KAKAO_REDIRECT_URI 같은 변수를 되살리지 말 것).
# IdP 콘솔에 등록하는 redirect_uri도 백엔드가 아니라 프론트 콜백 페이지 URL임.
# KAKAO_CLIENT_SECRET은 REST API 키가 아니라 콘솔의 진짜 Client Secret 값임.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- JWT (auth 도메인 구현 시) ---
# JWT_SECRET은 랜덤 32바이트 이상(openssl rand -base64 48). 로컬은 아무 값, prod는 ENV 시크릿.
# 리프레시는 불투명 랜덤 토큰을 MySQL에 저장하는 설계라, 리프레시 만료도 서버가 관리함.
JWT_SECRET=
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=1209600000

# --- 외부 공공 API (배치 구현 시점에 발급) ---
ODCLOUD_SERVICE_KEY=
YOUTHCENTER_API_KEY=

# =====================================================================
# 배포(prod, EC2) — GitHub Secrets의 ENV에 통째로 넣는 값의 예시.
# deploy.yml이 배포 때 이 형식으로 EC2 /home/ubuntu/.env를 생성함.
# 위 로컬 값과 달리 DB 호스트는 compose 서비스명 mysql이고 프로필은 prod임.
# =====================================================================
# SPRING_PROFILES_ACTIVE=prod
# DOCKERHUB_USERNAME=kwonseok02
# DB_URL=jdbc:mysql://mysql:3306/jeongbiseo?allowPublicKeyRetrieval=true&useSSL=false
# DB_USERNAME=root
# DB_PASSWORD=<강한-비밀번호>
# INGESTION_ENABLED=false
# ODCLOUD_SERVICE_KEY=
# YOUTHCENTER_API_KEY=
#
# 소셜 로그인 배포 시 추가(팀원 OAuth 키 전달받아 넣음):
# KAKAO_CLIENT_ID= / KAKAO_CLIENT_SECRET= / GOOGLE_CLIENT_ID= / GOOGLE_CLIENT_SECRET=
# JWT_SECRET=<랜덤 32바이트+>  없으면 prod가 부팅에 실패함(fail-fast).
# 프론트 도메인 확정 후 추가:
# CORS_ALLOWED_ORIGINS=<프론트 origin, 콤마 구분>  비면 아무 origin도 허용하지 않아 브라우저 요청이 전부 막힘.
# COOKIE_SAME_SITE=<None 또는 Strict>  기본 None. 프론트와 백엔드가 같은 사이트면 Strict.
