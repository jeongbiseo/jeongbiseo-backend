# 이 파일을 복사해 .env로 만들고 값을 채움. .env는 git에 올리지 않음.
#
# 주의: Spring Boot는 .env를 자동으로 읽지 않음. 아래 셋 중 하나로 주입함.
#   1) IntelliJ: Run/Debug Configurations -> Environment variables에 붙여넣기
#   2) bash:     set -a; source .env; set +a; ./gradlew bootRun --args='--spring.profiles.active=local'
#   3) PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^(\w+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }

# --- DB (compose.yml 기본값과 일치함) ---
DB_URL=jdbc:mysql://localhost:3306/jeongbiseo?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=jeongbiseo
DB_PASSWORD=jeongbiseo

# --- 소셜 로그인 (구현 시점에 발급) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 외부 공공 API (배치 구현 시점에 발급) ---
ODCLOUD_SERVICE_KEY=
YOUTHCENTER_API_KEY=
